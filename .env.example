NODE_ENV=development

# Browser-visible, non-sensitive values.
# Nuxt exposes NUXT_PUBLIC_* values to client-side code through runtimeConfig.public.
NUXT_PUBLIC_APP_NAME=super-agent-console
NUXT_PUBLIC_APP_VERSION=0.1.0
NUXT_PUBLIC_DEPLOY_ENV=local
NUXT_PUBLIC_CONFIG_DEMO_TEXT=hello-from-env-example
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side, non-sensitive values.
APP_NAME=super-agent-console
APP_VERSION=0.1.0
MODEL_PROVIDER=mock
MODEL_NAME=doubao-seed-2-0-lite-260428
MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MODEL_ENABLED=true
MODEL_TEMPERATURE=0.2
MODEL_TOP_P=0.8
MODEL_MAX_TOKENS=4096
LOG_LEVEL=info
MOCK_MODEL_ENABLED=true
RUN_RATE_LIMIT_MINUTE=3
RUN_RATE_LIMIT_DAY=30
GLOBAL_RUN_RATE_LIMIT_MINUTE=5
GLOBAL_RUN_RATE_LIMIT_DAY=100
CONCURRENT_RUNS_PER_USER=1
CONCURRENT_RUNS_GLOBAL=3
AUTH_LOGIN_RATE_LIMIT_MINUTE=10
MODEL_REQUEST_TIMEOUT_MS=180000
MAX_RUN_INPUT_LENGTH=5000

# Server-side, sensitive values. Do not expose these through runtimeConfig.public.
DATABASE_URL=mysql://sac_app:<MYSQL_APP_PASSWORD>@127.0.0.1:3306/super_agent_console_dev
MODEL_API_KEY=your_model_api_key
ACCESS_CODES=friend-a-code,friend-b-code
ADMIN_ACCESS_CODES=owner-admin-code
AUTH_COOKIE_SECRET=replace-with-random-long-string
DEMO_SERVER_TOKEN=your_demo_server_token
