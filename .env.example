NODE_ENV=development

# Browser-visible, non-sensitive values.
# Nuxt exposes NUXT_PUBLIC_* values to client-side code through runtimeConfig.public.
NUXT_PUBLIC_APP_NAME=super-agent-console
NUXT_PUBLIC_APP_VERSION=0.1.0
NUXT_PUBLIC_DEPLOY_ENV=local
NUXT_PUBLIC_CONFIG_DEMO_TEXT=hello-from-env-example
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side, non-sensitive values.
APP_NAME=super-agent-console
APP_VERSION=0.1.0
ARK_MODEL_ID=your_model_id
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LOG_LEVEL=info
MOCK_MODEL_ENABLED=true

# Server-side, sensitive values. Do not expose these through runtimeConfig.public.
DATABASE_URL=mysql://root:password@localhost:3306/super_agent_console
ARK_API_KEY=your_ark_api_key
DEMO_SERVER_TOKEN=your_demo_server_token
